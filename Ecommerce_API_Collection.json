    {
      "name": "Login API",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let JsonData = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"token\", JsonData.accessToken);\r",
              "\r",
              "console.log(pm.environment.get(\"token\"));\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"emilys\",\r\n    \"password\": \"emilyspass\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseurl}}/auth/login",
          "host": [
            "{{baseurl}}"
          ],
