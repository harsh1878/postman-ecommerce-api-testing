    {
      "name": "Add Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "let JsonData = pm.response.json();",
              "pm.test(\"Cart has products\", function () {",
              "    pm.expect(JsonData.products.length).to.be.above(0);",
              "})",
              "",
              "pm.test(\"Cart total is greater than 100\", function () {",
              "    pm.expect(JsonData.total).to.be.a('number');",
              "    pm.expect(JsonData.total).to.be.above(100);",
              "});",
              "",
              "pm.environment.set(\"Cart_id\", JsonData.id);",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.test(\"Quantity should not be 0\", function () {",
              "    let rawBody = pm.request.body.raw ? pm.variables.replaceIn(pm.request.body.raw) : \"{}\";",
              "    let body = JSON.parse(rawBody);",
              "    let products = body.products || [];",
              "    products.forEach(p => {",
              "        if (p.quantity === 0) {",
              "            throw new Error(\"Product is out of stock. Request aborted.\");",
              "        }",
              "        pm.expect(p.quantity).to.be.above(0, \"Product quantity must be greater than 0\");",
              "    });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"userId\": 1,\r\n    \"products\": [\r\n        {\r\n            \"id\": {{Product_id}},\r\n            \"quantity\": 11\r\n        }\r\n    ]\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseurl}}/carts/add",
          "host": [
            "{{baseurl}}"
          ],
          "path": [
            "carts",
            "add"
          ]
        }
      },
      "response": []
